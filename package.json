{
  "name": "@diottodev/runic",
  "version": "1.1.0",
  "description": "379 AI & Dev skills for Claude Code, Cursor, Windsurf, VS Code, and JetBrains — install via MCP.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "runic": "./dist/index.js",
    "@diottodev/runic": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "ai-research",
    "ai-security",
    "business",
    "c-level",
    "commercial",
    "compliance",
