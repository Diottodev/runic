    "marketing",
    "product",
    "productivity",
    "project-management",
    "research",
    "research-ops",
    "superpowers"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/index.js",
    "build:cursor-commands": "node scripts/generate-cursor-commands.mjs",
    "build:all": "npm run build && npm run build:cursor-commands",
    "prepare": "npm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "icons": "node scripts/generate-icons.mjs"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "runic",
    "claude-code",
